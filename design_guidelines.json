{
  "theme": "Dark",
  "archetype": "Archetype 5 (Jewel & Luxury) paired with Archetype 7 (Electric Accent) for an Art Portfolio aesthetic.",
  "colors": {
    "background": {
      "default": "#0A0A0A",
      "surface": "#171717",
      "surfaceElevated": "#262626",
      "tabBar": "#0F0F0F"
    },
    "primary": {
      "default": "#00E59B",
      "pressed": "#00C283",
      "subtle": "rgba(0, 229, 155, 0.15)"
    },
    "text": {
      "primary": "#FFFFFF",
      "secondary": "#A3A3A3",
      "tertiary": "#737373",
      "onPrimary": "#000000"
    },
    "border": {
      "default": "#262626",
      "focus": "#00E59B"
    },
    "feedback": {
      "error": "#EF4444",
      "success": "#22C55E"
    }
  },
  "typography": {
    "instructions": "Use 'expo-google-fonts' to load 'Outfit' for all headings/accents, and 'Manrope' for body copy. Avoid Inter or Roboto.",
    "fonts": {
      "heading": "Outfit",
      "body": "Manrope"
    },
    "scale": {
      "h1": {
        "fontSize": 32,
        "fontFamily": "Outfit_700Bold",
        "lineHeight": 40,
        "letterSpacing": -0.5
      },
      "h2": {
        "fontSize": 24,
        "fontFamily": "Outfit_600SemiBold",
        "lineHeight": 32,
        "letterSpacing": -0.5
      },
      "h3": {
        "fontSize": 20,
        "fontFamily": "Outfit_600SemiBold",
        "lineHeight": 28,
        "letterSpacing": -0.5
      },
      "bodyLarge": {
        "fontSize": 16,
        "fontFamily": "Manrope_500Medium",
        "lineHeight": 24
      },
      "body": {
        "fontSize": 14,
        "fontFamily": "Manrope_400Regular",
        "lineHeight": 20
      },
      "caption": {
        "fontSize": 12,
        "fontFamily": "Manrope_500Medium",
        "lineHeight": 16,
        "letterSpacing": 0.2
      },
      "button": {
        "fontSize": 16,
        "fontFamily": "Outfit_600SemiBold",
        "lineHeight": 24,
        "letterSpacing": 0.2
      }
    }
  },
  "spacing": {
    "2xs": 4,
    "xs": 8,
    "sm": 12,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "2xl": 48
  },
  "radii": {
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 24,
    "full": 9999
  },
  "elevation_and_shadows": {
    "card": {
      "elevation": 4,
      "shadowColor": "#000000",
      "shadowOffset": {
        "width": 0,
        "height": 4
      },
      "shadowOpacity": 0.2,
      "shadowRadius": 12
    },
    "button": {
      "elevation": 6,
      "shadowColor": "#00E59B",
      "shadowOffset": {
        "width": 0,
        "height": 4
      },
      "shadowOpacity": 0.25,
      "shadowRadius": 8
    }
  },
  "components": {
    "artworkCard": {
      "layout": "Masonry or Grid item. Image occupies 100% width, height varies by aspect ratio.",
      "style": {
        "borderRadius": "radii.lg",
        "backgroundColor": "colors.background.surface",
        "overflow": "hidden"
      },
      "textContainer": {
        "padding": "spacing.md"
      },
      "animations": {
        "pressScale": 0.97,
        "duration": 150
      }
    },
    "primaryButton": {
      "style": {
        "backgroundColor": "colors.primary.default",
        "borderRadius": "radii.full",
        "paddingVertical": "spacing.md",
        "paddingHorizontal": "spacing.lg",
        "alignItems": "center"
      },
      "textStyle": {
        "color": "colors.text.onPrimary",
        "fontFamily": "Outfit_600SemiBold"
      },
      "animations": {
        "pressScale": 0.95,
        "backgroundColorOnPress": "colors.primary.pressed"
      }
    },
    "secondaryButton": {
      "style": {
        "backgroundColor": "transparent",
        "borderWidth": 1,
        "borderColor": "colors.border.default",
        "borderRadius": "radii.full",
        "paddingVertical": "spacing.md",
        "paddingHorizontal": "spacing.lg",
        "alignItems": "center"
      }
    },
    "priceChip": {
      "style": {
        "backgroundColor": "colors.primary.subtle",
        "borderRadius": "radii.full",
        "paddingVertical": "spacing.2xs",
        "paddingHorizontal": "spacing.sm"
      },
      "textStyle": {
        "color": "colors.primary.default",
        "fontFamily": "Outfit_700Bold",
        "fontSize": 14
      }
    },
    "inputField": {
      "style": {
        "backgroundColor": "colors.background.surface",
        "borderWidth": 1,
        "borderColor": "colors.border.default",
        "borderRadius": "radii.md",
        "padding": "spacing.md",
        "color": "colors.text.primary"
      },
      "focusStyle": {
        "borderColor": "colors.primary.default"
      }
    },
    "bottomTabBar": {
      "style": {
        "backgroundColor": "colors.background.tabBar",
        "borderTopWidth": 1,
        "borderTopColor": "colors.border.default",
        "height": 60,
        "paddingBottom": 8
      },
      "activeTintColor": "colors.primary.default",
      "inactiveTintColor": "colors.text.tertiary"
    }
  },
  "screens": {
    "Login": {
      "layout": "Centered layout with high-impact visual.",
      "guidance": "Use Emergent-managed Google social login. Display 'Continue with Google' button. Background can be a darkened hero image with a deep radial gradient overlay."
    },
    "Home": {
      "layout": "Masonry feed (e.g. FlashList with MasonryLayout or @react-native-seoul/masonry-list).",
      "guidance": "Top header with App Logo left-aligned, Search icon right-aligned. Cards show Image, Title, Author, Price."
    },
    "Detail": {
      "layout": "ScrollView with Edge-to-edge header image.",
      "guidance": "Artwork fills top space, fading into surface color using LinearGradient. Title, Author Avatar + Name inline. Description paragraph. Sticky bottom view with Price and 'Add to Cart' button."
    },
    "Upload": {
      "layout": "Form layout wrapped in KeyboardAvoidingView and ScrollView.",
      "guidance": "Large image picker region at the top (dashed border, placeholder icon). Inputs for Title, Description (multiline), Price. Sticky 'Upload Artwork' primary button."
    },
    "Cart": {
      "layout": "FlatList of cart items.",
      "guidance": "Each row shows a small square thumbnail, Title, Price, and Remove (Trash) icon. Bottom fixed section shows Total Price and 'Buy Now' fake checkout button. If empty, show Empty State illustration and text."
    },
    "Profile": {
      "layout": "Header with Google user info, followed by a grid of user's uploads.",
      "guidance": "Avatar centered, large name, email. 'Logout' button with secondary outline style. Grid of uploaded artworks below."
    }
  },
  "media": {
    "icons": {
      "library": "lucide-react-native",
      "strokeWidth": 2,
      "size": {
        "sm": 20,
        "md": 24,
        "lg": 32
      }
