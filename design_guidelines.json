  "motion_and_interactions": {
    "press_scale": {
      "active": 0.96,
      "animation": "spring",
      "damping": 15,
      "stiffness": 300
    },
    "list_stagger": {
      "type": "fade_slide_up",
      "delay": 50,
      "duration": 300
    },
    "page_transition": {
      "type": "fade",
      "duration": 200
    }
  },
  "testing": {
    "attributes": "All interactive elements MUST use testID attribute (React Native standard instead of data-testid). E.g. testID='login-google-button'."
  }
}